{
  "name": "pzero",
  "version": "0.1.0",
  "private": true,
  "description": "Phoenix OS — next-generation AI-native platform for Intellect Design Arena",
  "scripts": {
    "build": "pnpm -r run build",
    "test": "pnpm -r run test",
    "lint": "eslint \"packages/**/*.ts\" --max-warnings 0",
    "typecheck": "pnpm -r run typecheck",
    "clean": "pnpm -r run clean",
    "benchmark": "pnpm --filter @pzero/kernel run build && pnpm --filter @pzero/kernel run benchmark"
  },
  "engines": {
    "node": ">=20"
  },
  "packageManager": "pnpm@9.14.2",
  "devDependencies": {
    "@typescript-eslint/eslint-plugin": "^7.18.0",
    "@typescript-eslint/parser": "^7.18.0",
    "eslint": "^8.57.0",
    "eslint-config-prettier": "^9.1.0",
    "prettier": "^3.4.2"
  }
}
