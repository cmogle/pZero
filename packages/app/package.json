{
  "name": "@pzero/app",
  "version": "0.1.0",
  "private": true,
  "description": "Phoenix OS application layer — user-facing workflows and APIs",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": { "types": "./dist/index.d.ts", "import": "./dist/index.js" },
    "./components": { "types": "./dist/components/index.d.ts", "import": "./dist/components/index.js" }
  },
  "scripts": {
    "build": "tsc",
    "test": "vitest run",
    "lint": "eslint . --ext .ts",
    "typecheck": "tsc --noEmit",
    "clean": "rm -rf dist"
  },
  "dependencies": {
    "@pzero/runtime": "workspace:*",
    "react": "^18.3.0"
  },
  "devDependencies": {
    "@types/node": "^22.10.0",
    "@types/react": "^18.3.0",
    "typescript": "^5.7.0",
    "vitest": "^2.1.0"
  }
}
